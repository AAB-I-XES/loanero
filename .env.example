# GEMINI_API_KEY: Required for Gemini AI API calls.
# This is a placeholder key.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY=MY_GEMINI_API_KEY

# SUPABASE_URL: The URL of your Supabase project (e.g. https://xyz.supabase.co)
SUPABASE_URL=YOUR_SUPABASE_URL_HERE

# SUPABASE_ANON_KEY: The public anon key for your Supabase project
SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY_HERE

# GOOGLE_CLIENT_ID: The OAuth Web Client ID for Google Sign-In
GOOGLE_CLIENT_ID=YOUR_GOOGLE_CLIENT_ID_HERE
